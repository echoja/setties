{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": [
    "checks"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "label",
          "kind",
          "expected"
        ],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "label": {
            "type": "string",
            "minLength": 1
          },
          "kind": {
            "type": "string",
            "enum": [
              "tcp",
              "launchd",
              "process",
              "command"
            ]
          },
          "expected": {
            "type": "string"
          },
          "host": {
            "type": "string",
            "minLength": 1
          },
          "port": {
            "type": "integer",
            "minimum": 1,
            "maximum": 65535
          },
          "domain": {
            "type": "string",
            "enum": [
              "system",
              "user"
            ]
          },
          "service": {
            "type": "string",
            "minLength": 1
          },
          "pattern": {
            "type": "string",
            "minLength": 1
          },
          "argv": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "profiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "exceptProfiles": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fix": {
            "type": "string",
            "minLength": 1
          }
        },
        "allOf": [
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "tcp"
                }
              }
            },
            "then": {
              "required": [
                "host",
                "port"
              ],
              "properties": {
                "expected": {
                  "enum": [
                    "open",
                    "closed"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "launchd"
                }
              }
            },
            "then": {
              "required": [
                "domain",
                "service"
              ],
              "properties": {
                "expected": {
                  "enum": [
                    "enabled",
                    "disabled"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "process"
                }
              }
            },
            "then": {
              "required": [
                "pattern"
              ],
              "properties": {
                "expected": {
                  "enum": [
                    "running",
                    "stopped"
                  ]
                }
              }
            }
          },
          {
            "if": {
              "properties": {
                "kind": {
                  "const": "command"
                }
              }
            },
            "then": {
              "required": [
                "argv"
              ],
              "properties": {
                "expected": {
                  "const": "success"
                }
              }
            }
          }
        ]
      }
    }
  }
}
