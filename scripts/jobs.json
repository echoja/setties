{
  "$schema": "./jobs.schema.json",
  "jobs": [
    {
      "label": "com.echoja.setties-pull",
      "description": "Daily auto-pull of Setties repo",
      "script": "scripts/auto-pull.sh",
      "schedule": {
        "hour": 9,
        "minute": 0
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "label": "com.echoja.brew-upgrade",
      "description": "Daily auto-upgrade of Homebrew packages",
      "script": "scripts/brew-upgrade.sh",
      "schedule": {
        "hour": 10,
        "minute": 0
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "label": "com.echoja.omz-update",
      "description": "Daily auto-update of Oh My Zsh",
      "script": "scripts/omz-update.sh",
      "schedule": {
        "hour": 10,
        "minute": 30
      },
      "environment": {
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"
      }
    },
    {
      "label": "com.echoja.ttyd-tmux",
      "description": "Persistent ttyd web terminal attached to an existing tmux session",
      "script": "scripts/ttyd-tmux.sh",
      "schedule": {},
      "environment": {
        "LANG": "ko_KR.UTF-8",
        "LC_ALL": "ko_KR.UTF-8",
        "LC_CTYPE": "ko_KR.UTF-8",
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
        "TERM": "xterm-256color",
        "TTYD_BASE_PATH": "/ttyd",
        "TTYD_FONT_FAMILY": "Menlo, Monaco, 'Apple SD Gothic Neo', 'Apple Color Emoji', monospace",
        "TTYD_HOST": "127.0.0.1",
        "TTYD_PORT": "7682",
        "TTYD_TMUX_SESSION": "remote"
      },
      "run_at_load": true,
      "keep_alive": true
    },
    {
      "label": "com.echoja.ttyd-mobile-control",
      "description": "Mobile browser wrapper with tmux scroll controls for ttyd",
      "script": "scripts/ttyd-mobile-control.sh",
      "schedule": {},
      "environment": {
        "LANG": "ko_KR.UTF-8",
        "LC_ALL": "ko_KR.UTF-8",
        "LC_CTYPE": "ko_KR.UTF-8",
        "PATH": "/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin",
        "TTYD_BACKEND_HOST": "127.0.0.1",
        "TTYD_MOBILE_HOST": "tailscale",
        "TTYD_MOBILE_PORT": "7681",
        "TTYD_PORT": "7682",
        "TTYD_TMUX_SESSION": "remote"
      },
      "run_at_load": true,
      "keep_alive": true
    }
  ]
}
